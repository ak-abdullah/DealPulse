# Copy to .env and fill in values.

HUBSPOT_API_KEY=
STALE_DEAL_DAYS=7
# Use 0 to treat every open deal as stalled (local testing only)

# Set to true to use fixture deals without calling HubSpot (local dev / CI)
HUBSPOT_USE_MOCK=false

# Groq (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gmail (https://console.cloud.google.com)
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
SENDER_EMAIL=
SENDER_NAME=

# Set to true to log sends without calling Gmail (local dev / CI)
GMAIL_USE_MOCK=false

# Built-in daily scheduler (off by default — use python main.py or run_worker.py --once)
SCHEDULER_ENABLED=false
SCHEDULER_HOUR=9
SCHEDULER_MINUTE=0
SCHEDULER_TIMEZONE=UTC

# LangSmith (optional — https://smith.langchain.com)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=sentinel
